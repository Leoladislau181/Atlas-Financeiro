# URL do seu projeto Supabase (obrigatório para o frontend e backend)
VITE_SUPABASE_URL="sua_url_do_supabase_aqui"

# Chave pública anônima do Supabase (obrigatório para o frontend)
VITE_SUPABASE_ANON_KEY="sua_chave_anonima_do_supabase_aqui"

# Chave de serviço (Service Role) do Supabase (obrigatório para o backend/admin)
# Usada para contornar o RLS e realizar ações administrativas seguras.
SUPABASE_SERVICE_ROLE_KEY="sua_chave_service_role_aqui"

# APP_URL: A URL onde este app está hospedado.
# O ambiente injeta isso automaticamente.
APP_URL="SUA_APP_URL"
